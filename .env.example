# Construction Violation AI — environment template
# Copy to `.env` and fill in. `.env` is gitignored.

# ---------- AI provider (pick ONE of the two blocks below) ----------

# --- Option A: OpenRouter (multi-provider gateway, no batch discount) ---
# Console: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# Model slug. Default is Gemini 2.5 Flash — won a 50-photo head-to-head eval
# (see scripts/evaluate_models.py) with +12pp HSE accuracy AND 89% lower cost
# than Sonnet 4.5. Alternatives:
#   anthropic/claude-sonnet-4.5    (previous default — slightly weaker, much pricier)
#   anthropic/claude-opus-4.5      (best accuracy: +10pp; 4.8x Sonnet cost)
#   google/gemini-2.5-pro          (heavy reasoning; truncates at 3000 tokens)
#   anthropic/claude-haiku-4.5     (cheapest Anthropic option)
OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional — shown in OpenRouter analytics so you can see which app is spending:
OPENROUTER_REFERER=https://violation-ai-webapp.fly.dev
OPENROUTER_TITLE=Violation AI

# --- Option B: Anthropic direct (enables 50%-off Batch API) ---
# Console: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ---------- Supabase (Postgres + Auth) ----------
# Project settings: https://app.supabase.com → your project → Project Settings → API
SUPABASE_URL=https://REPLACE_ME.supabase.co
# The service-role key bypasses RLS — server-side only, NEVER ship to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...REPLACE_ME
# Optional: anon key for client-side usage if you add a public-facing page.
SUPABASE_ANON_KEY=eyJhbGciOi...REPLACE_ME

# ---------- Cloudflare R2 (photo storage) ----------
# Console: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET=aecis-violations

# ---------- App auth (MVP: HTTP Basic) ----------
# When set, all UI endpoints require Basic auth. Username fixed to "admin".
APP_ADMIN_PASSWORD=change-me-please

# ---------- Email export (Phase 3) ----------
# Set these to enable the "Email it" button in the export menu.
# Without them, the endpoint returns 503 "email_not_configured" and the
# button shows that error inline; everything else keeps working.
#
# Recommended: Gmail SMTP with an app-specific password.
#   1. Enable 2FA on the Gmail account
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Generate an app password for "Mail" → "Other (Violation AI)"
#   4. Use that 16-character string as SMTP_PASSWORD below
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-sender@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=AECIS HSE <your-sender@gmail.com>
# SMTP_USE_TLS=1
# Per-cookie-id daily cap on email-export sends (default 5).
# EMAIL_DAILY_PER_USER=5
# Inline-attachment max bytes (default ~20MB; bigger = R2 link instead).
# EMAIL_INLINE_LIMIT_BYTES=20971520

# ---------- Admin gate (Phase 2 stopgap; replaced by Phase 5 OAuth) ----------
# When set, /admin/login + /admin/stats become available. Use a strong
# random string. The cookie value IS the password — short-lived (12h).
# ADMIN_PASSWORD=replace-with-strong-random-string

# ---------- Quota (Phase 2) ----------
# Free-tier daily classification cap per cookie-id. Default 30.
# QUOTA_FREE_PER_DAY=30

# ---------- Optional ----------
# Override taxonomy location (defaults to <repo>/taxonomy.json).
# VIOLATION_TAXONOMY=/app/taxonomy.json

# Port the FastAPI app binds to (defaults to 8000).
# PORT=8000

# Budget guard (daily USD cap on AI spend). Not enforced yet — reserved for v2.
# DAILY_BUDGET_USD=10.00
